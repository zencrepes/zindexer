{
  "name": "zindexer",
  "description": "Fetches data from GitHub, Jira and pushes it to Elasticsearch",
  "version": "0.0.1",
  "author": "Francois Gerthoffert @Fgerthoffert",
  "bin": {
    "zindexer": "./bin/run"
  },
  "bugs": "https://github.com/zencrepes/zindexer/issues",
  "dependencies": {
    "@elastic/elasticsearch": "^7.17.14",
    "@oclif/command": "^1.8.36",
    "@oclif/config": "^1.18.17",
    "@oclif/plugin-help": "^2.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node-fetch": "^2.6.13",
    "apollo-cache-inmemory": "^1.6.6",
    "apollo-client": "^2.6.10",
    "apollo-link": "^1.2.14",
    "apollo-link-http": "^1.5.17",
    "asciitable.js": "^2.0.1",
    "axios": "^1.18.1",
    "cli-ux": "^5.6.7",
    "crypto-random-string": "^3.3.1",
    "date-fns": "^4.4.0",
    "fs-extra": "^11.3.5",
    "graphql": "^14.7.0",
    "graphql-tag": "^2.12.7",
    "jira2md": "^3.0.1",
    "js-yaml": "^4.1.0",
    "load-yaml-file": "^0.2.0",
    "lodash": "^4.18.1",
    "node-fetch": "^2.7.0",
    "nodejs-file-downloader": "^4.13.0",
    "p-map": "^4.0.0",
    "sqlite3": "^5.1.7",
    "tslib": "^2.8.1",
    "uuid": "^10.0.0",
    "uuid-by-string": "^3.0.7",
    "xml-js": "^1.6.11",
    "xregexp": "^5.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@oclif/dev-cli": "^1.26.10",
    "@oclif/test": "^1.2.9",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "chai": "^4.5.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globby": "^11.1.0",
    "c8": "^10.1.3",
    "mocha": "^11.7.6",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "/bin",
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/zencrepes/zindexer",
  "keywords": [
    "oclif"
  ],
  "license": "LGPL-2.1",
  "main": "lib/index.js",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "zindexer",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "github": {
        "description": "Fetches data from GitHub"
      },
      "jira": {
        "description": "Fetches data from Jira"
      },
      "circleci": {
        "description": "Fetches data from Circleci"
      },
      "utils": {
        "description": "Set of one-off utility functions"
      }
    }
  },
  "repository": "zencrepes/zindexer",
  "scripts": {
    "build": "tsc -b",
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "rm -rf lib && tsc -b && oclif-dev readme",
    "test": "tsc -p tsconfig.test.json && c8 mocha --forbid-only",
    "lint": "eslint . --fix"
  },
  "types": "lib/index.d.ts",
  "bit": {
    "env": {
      "compiler": {
        "bit.envs/compilers/typescript@3.1.47": {
          "rawConfig": {
            "tsconfig": {
              "compilerOptions": {
                "declaration": true,
                "importHelpers": true,
                "esModuleInterop": true,
                "module": "commonjs",
                "strict": true,
                "target": "es2017",
                "composite": true,
                "sourceMap": true,
                "noImplicitAny": true,
                "skipLibCheck": true,
                "lib": [
                  "esnext"
                ]
              }
            }
          }
        }
      }
    },
    "componentsDefaultDirectory": "components/{name}",
    "packageManager": "yarn"
  }
}
